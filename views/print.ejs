<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Print Token</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
    }

    body {
      background: #f4f7f8;
      color: #000;
      padding: 20px;
      display: flex;
      justify-content: center;
    }

    .slip {
      width: 280px;
      background: #fff;
      border: 1px solid #000;
      padding: 12px;
      text-align: center;
    }

    .logo {
      width: 55px;
      height: 55px;
      object-fit: contain;
      display: block;
      margin: 0 auto 8px;
    }

    .title {
      font-size: 16px;
      font-weight: bold;
      margin-bottom: 4px;
    }

    .subtitle {
      font-size: 13px;
      margin-bottom: 10px;
    }

    .token-box {
      border: 1px dashed #000;
      padding: 10px;
      margin: 10px 0;
    }

    .token-label {
      font-size: 11px;
      margin-bottom: 4px;
      text-transform: uppercase;
    }

    .token-number {
      font-size: 30px;
      font-weight: bold;
    }

    .line {
      border-top: 1px dashed #000;
      margin: 10px 0;
    }

    .detail {
      text-align: left;
      font-size: 13px;
      margin: 6px 0;
      word-break: break-word;
    }

    .footer-note {
      font-size: 11px;
      margin-top: 10px;
      line-height: 1.5;
    }

    .actions {
      margin-top: 14px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .btn {
      padding: 10px;
      border: none;
      cursor: pointer;
      font-size: 13px;
      font-weight: bold;
      text-decoration: none;
      display: block;
      text-align: center;
    }

    .btn-print {
      background: #0b7a75;
      color: #fff;
    }

    .btn-admin {
      background: #fff;
      color: #000;
      border: 1px solid #000;
    }

    @media print {
      @page {
        size: 58mm auto;
        margin: 4mm;
      }

      body {
        background: #fff;
        padding: 0;
      }

      .slip {
        width: 58mm;
        border: none;
        padding: 0;
      }

      .actions {
        display: none !important;
      }
    }
  </style>
</head>
<body>
  <div class="slip">
    <img src="/images/logo.png" alt="Jan Seva Samarpan Trust Logo" class="logo">

    <div class="title">Jan Seva Samarpan Trust</div>
    <div class="subtitle">Free Medical Camp</div>

    <div class="line"></div>

    <div class="token-box">
      <div class="token-label">Token Number</div>
      <div class="token-number"><%= token.token_number %></div>
    </div>

    <div class="detail"><strong>Name:</strong> <%= token.name %></div>
    <div class="detail"><strong>Phone:</strong> <%= token.phone || 'N/A' %></div>
    <div class="detail"><strong>Service:</strong> <%= token.service || 'General' %></div>
    <div class="detail"><strong>Time:</strong> <%= token.slot_time || 'N/A' %></div>

    <div class="line"></div>

    <div class="footer-note">
      Please arrive 10 minutes early.<br>
      Keep this token slip safe.
    </div>

    <div class="actions">
      <button class="btn btn-print" onclick="window.print()">Print Slip</button>
      <a href="/admin" class="btn btn-admin">Go to Admin Panel</a>
    </div>
  </div>
</body>
</html>