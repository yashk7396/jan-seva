<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Print Token</title>

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: Arial;
}

body {
  background: #f5f5f5;
  display: flex;
  justify-content: center;
  padding: 20px;
}

/* HEADER */
.header-top {
  background: linear-gradient(90deg, #ff4d00, #ff6a00);
  color: white;
  padding: 10px;
  text-align: center;
  font-size: 16px;
  font-weight: bold;
}

.header-bottom {
  background: #004aad;
  color: white;
  text-align: center;
  padding: 4px;
  font-size: 12px;
}

/* SLIP CARD */
.slip {
  width: 280px;
  background: #fff;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 8px 20px rgba(0,0,0,0.1);
}

/* LOGO */
.logo {
  width: 60px;
  display: block;
  margin: 10px auto;
}

/* TITLE */
.title {
  text-align: center;
  font-size: 14px;
  font-weight: bold;
}

/* TOKEN */
.token-box {
  text-align: center;
  margin: 10px;
  padding: 10px;
  border: 1px dashed #000;
}

.token-number {
  font-size: 28px;
  font-weight: bold;
  margin-top: 5px;
}

/* DETAILS */
.detail {
  font-size: 13px;
  margin: 5px 12px;
  font-weight: bold;

}

/* LINE */
.line {
  border-top: 1px dashed #000;
  margin: 8px 10px;
}

/* FOOTER */
.footer {
  background: linear-gradient(90deg, #ff4d00, #ff6a00);
  color: white;
  text-align: center;
  padding: 6px;
  font-size: 11px;
  margin-top: 10px;
}

/* BUTTONS */
.actions {
  margin-top: 10px;
  padding: 10px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.btn {
  padding: 8px;
  font-size: 12px;
  font-weight: bold;
  border: none;
  cursor: pointer;
}

.btn-print {
  background: #ff4d00;
  color: white;
}

.btn-admin {
  background: white;
  border: 1px solid #000;
}

/* PRINT */
@media print {
  @page {
    size: 58mm auto;
    margin: 2mm;
  }

  body {
    padding: 0;
  }

  .slip {
    width: 58mm;
    box-shadow: none;
  }

  .actions {
    display: none;
  }
}
</style>
</head>

<body>

<div class="slip">



  

  <!-- LOGO -->
  <img src="/images/logo.png" class="logo">

  <b><div class="title">Jan Seva Samarpan Trust</div></b>
  <!-- ADDRESS -->
 <b> <div class="detail" style="font-size:13px;">
    📍 RZ 27-B, Durga Park, Street No. 9<br>
    New Delhi - 110045
  </div>

  <div class="detail" style="font-size:13px;">
    📞 9911106799 , 7900470005
  </div>

  <div class="detail" style="font-size:13px;">
    🌐 jansevasamarpantrust.in
  </div></b>


  <div class="line"></div>

  <!-- TOKEN -->
  <div class="token-box">
    TOKEN NO
    <div class="token-number"><%= token.token_number %></div>
  </div>

  <!-- DETAILS -->
  <div class="detail"><strong>Name:</strong> <%= token.name %></div>
  <div class="detail"><strong>Phone:</strong> <%= token.phone %></div>
  <div class="detail"><strong>Location:</strong> <%= token.place %></div>
  <div class="detail"><strong>Service:</strong> <%= token.service %></div>
  <div class="detail"><strong>Time:</strong> <%= token.slot_time %></div>

  <div class="line"></div>

  
  <div class="detail" style="text-align:center; font-size:12px;">
  <b> Please arrive 10 minutes early</b>
  </div>

  <!-- ACTIONS -->
  <div class="actions">
    <button class="btn btn-print" onclick="window.print()">Print</button>
    <button onclick="window.location.href='/admin'" class="btn btn-admin">
  Admin Panel
</button>
  </div>

</div>

</body>
</html>
