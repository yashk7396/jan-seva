<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jan Seva Samarpan Trust</title>

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: Arial;
}

body {
  background: #f5f5f5;
}

/* HEADER (ORANGE) */
.header-top {
  background: linear-gradient(90deg, #ff4d00, #ff6a00);
  color: white;
  padding: 15px;
  text-align: center;
  font-size: 22px;
  font-weight: bold;
}

/* BLUE STRIP */
.header-bottom {
  background: #004aad;
  color: white;
  text-align: center;
  padding: 6px;
  font-size: 14px;
}

/* MAIN CARD */
.container {
  max-width: 420px;
  margin: 30px auto;
  background: white;
  border-radius: 10px;
  padding: 25px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

/* LOGO */
.logo {
  width: 80px;
  display: block;
  margin: 0 auto 10px;
}

/* TITLE */
.title {
  text-align: center;
  color: #0b5d5d;
  margin-bottom: 10px;
}

/* INFO */
.info {
  text-align: center;
  font-size: 13px;
  color: #555;
  margin-bottom: 15px;
  line-height: 1.6;
}

.info b {
  display: block;
}

/* FORM */
form {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

label {
  font-weight: bold;
  font-size: 14px;
}

input, select {
  padding: 10px;
  border-radius: 8px;
  border: 1px solid #ccc;
}

/* BUTTON */
button {
  padding: 12px;
  background: #ff4d00;
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 16px;
  cursor: pointer;
}

button:hover {
  background: #e84300;
}

/* FOOTER */
.footer {
  background: linear-gradient(90deg, #ff4d00, #ff6a00);
  color: white;
  text-align: center;
  padding: 10px;
  font-size: 13px;
  margin-top: 20px;
}
</style>

</head>

<body>

<!-- HEADER -->
<div class="header-top">
  Jan Seva Samarpan Trust
</div>

<!-- FORM CARD -->
<div class="container">

  <img src="/images/logo.png" class="logo">

  <h2 class="title">Jan Seva Samarpan Trust</h2>

  <div class="info">
    <b>📍 RZ 27-B, Durga Park, Street No. 9</b>
    <b>Near Shiv Mandir, New Delhi - 110045</b>

    <b>📞 9911106799 , 7900470005</b>

    <b>🌐 jansevasamarpantrust.in | jansevasamarpantrust.org</b>
  </div>

  <form action="/generate" method="POST">

    <label>Full Name</label>
    <input type="text" name="name" required>

    <label>Phone Number</label>
    <input type="tel" name="phone" required>

    <label>Location</label>
    <input type="text" name="place" required>

    <label>Select Service</label>
    <select name="service" required>
      <option value="">Select</option>
      <option>Eye Checkup</option>
      <option>General Checkup</option>
      <option>Lab Test</option>
    </select>

    <button type="submit">Get Token</button>

  </form>

</div>


</body>
</html>
